# ============================================================================
# Enterprise Document Assistant - configuration
# Copy to .env and adjust. Every variable maps to app/core/config.py:Settings.
# ============================================================================

# --- Application -----------------------------------------------------------
APP_NAME="Enterprise Document Assistant"
ENVIRONMENT=development            # development | production | test
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
LOG_JSON=true                      # false = human-readable console logs (dev)

# --- Security --------------------------------------------------------------
# Comma-separated list of valid API keys (sent as X-API-Key header).
# Leave EMPTY to disable auth entirely (development only - a warning is logged).
API_KEYS=dev-secret-key
RATE_LIMIT_ENABLED=true
RATE_LIMIT=60/minute               # slowapi notation, per API key (falls back to client IP)

# --- Storage ---------------------------------------------------------------
DATA_DIR=data                      # uploads, sqlite db and chroma live under here
DATABASE_URL=sqlite+aiosqlite:///data/app.db   # any SQLAlchemy async URL (e.g. postgresql+asyncpg://...)
MAX_UPLOAD_SIZE_MB=25

# --- Vector store (ChromaDB) -------------------------------------------------
CHROMA_MODE=embedded               # embedded (persistent, local dir) | http (separate server, docker-compose)
CHROMA_PERSIST_DIR=data/chroma
CHROMA_HOST=localhost              # used when CHROMA_MODE=http
CHROMA_PORT=8001
CHROMA_COLLECTION=documents

# --- Chunking ----------------------------------------------------------------
CHUNKING_STRATEGY=recursive        # recursive (semantic can be added; see app/rag/chunking)
CHUNK_SIZE=1000                    # characters
CHUNK_OVERLAP=200

# --- Embeddings --------------------------------------------------------------
EMBEDDING_PROVIDER=sentence_transformers   # sentence_transformers | openai | fake (tests/offline)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5     # any sentence-transformers model id
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=32

# --- Retrieval ---------------------------------------------------------------
TOP_K=4                            # chunks handed to the LLM
FETCH_K=20                         # candidates fetched before MMR/rerank
SIMILARITY_THRESHOLD=0.25          # cosine similarity floor; below = discarded
USE_MMR=true                       # maximal marginal relevance for diversity
MMR_LAMBDA=0.5                     # 1.0 = pure relevance, 0.0 = pure diversity
RERANK_ENABLED=false               # cross-encoder reranking (downloads a model on first use)
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
HYBRID_SEARCH_ENABLED=false        # BM25 + vector fusion
HYBRID_ALPHA=0.5                   # weight of the vector score in the fusion (0..1)

# --- LLM ---------------------------------------------------------------------
LLM_PROVIDER=ollama                # openai | ollama | fake (tests/offline)
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=120

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=                 # optional: point at a compatible gateway

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
